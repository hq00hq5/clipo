<Window x:Class="Clipo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Clipo"
        Title="Clipo" Height="450" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="#1E1E1E"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="CenterScreen"
        Deactivated="Window_Deactivated" PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border BorderBrush="#3D3D3D" BorderThickness="1" CornerRadius="5">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Padding="8"
                         Background="#2D2D2D" Foreground="White" BorderBrush="#3D3D3D" BorderThickness="1"
                         TextChanged="SearchBox_TextChanged" PreviewKeyDown="SearchBox_PreviewKeyDown" FontSize="14" CaretBrush="White" />
                <Button Grid.Column="1" Content="X" Width="20" Height="20" Margin="10,0,0,0"
                        Background="Transparent" BorderThickness="0" Foreground="#555" Cursor="Hand"
                        VerticalAlignment="Center" Click="ExitButton_Click" ToolTip="Exit Clipo" />
            </Grid>
                     
            <ListBox x:Name="HistoryList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                     Foreground="White" VirtualizingStackPanel.IsVirtualizing="True" 
                     VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock local:HighlightBehavior.FullText="{Binding Text}" 
                                       local:HighlightBehavior.HighlightText="{Binding ElementName=SearchBox, Path=Text}"
                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Height="36" FontSize="13" Foreground="#D4D4D4"/>
                            <Button Grid.Column="1" Content="📋" Width="30" Height="30" Margin="10,0,0,0" 
                                    Background="Transparent" BorderThickness="0" Foreground="#888" Cursor="Hand"
                                    Click="CopyButton_Click" Tag="{Binding Text}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D30"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Border>
</Window>
